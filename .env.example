# Discord Support Bot - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Section 1: Discord Bot (Required)
# =============================================================================
# Your Discord bot token from https://discord.com/developers/applications
# Required - the bot will not start without this
DISCORD_TOKEN=your_discord_bot_token_here

# Command prefix for text commands (default: !)
# Used when bot is mentioned or for commands like !help
COMMAND_PREFIX=!

# Support System Configuration
# These IDs configure where the bot operates for support functionality
# Right-click channels/categories in Discord Developer Mode to get IDs

# Discord Guild ID where the bot provides support
SUPPORT_GUILD_ID=

# Channel ID for support tickets and general support
SUPPORT_CHANNEL_ID=

# Category ID where support tickets will be created
TICKET_CATEGORY_ID=

# Forum channel ID for support forum threads
SUPPORT_FORUM_ID=

# =============================================================================
# Section 2: Database (Required)
# =============================================================================
# PostgreSQL is recommended for production
# Format: postgresql://user:password@host:port/database
# SQLite fallback: sqlite:///path/to/database.db
DATABASE_URL=postgresql://user:password@localhost:5432/supportbot

# Redis connection URL for caching, rate limiting, and message queues
# Format: redis://host:port/database
REDIS_URL=redis://localhost:6379/0

# Alternative Redis URL for task backends (defaults to REDIS_URL if not set)
REDIS_BACKEND_URL=redis://localhost:6379/0

# Database connection pool settings (optional)
# Number of connections to maintain in the pool
DB_POOL_SIZE=10

# Maximum number of connections to create beyond pool_size
DB_MAX_OVERFLOW=20

# Seconds to wait for a connection from the pool before timing out
DB_POOL_TIMEOUT=30

# Seconds after which to recycle connections
DB_POOL_RECYCLE=3600

# Enable SQL echo for debugging (true/false)
DB_ECHO=false

# =============================================================================
# Section 3: AI Providers (At least one required)
# =============================================================================
# The bot requires at least one AI provider to be configured
# All providers below are optional - configure the ones you want to use

# OpenAI (GPT-4, GPT-3.5, etc.)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (Fast inference for open models)
# Get your key from: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter (Access to many models)
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=

# Ollama Cloud (Hosted Ollama)
# For using managed Ollama instances
OLLAMA_CLOUD_KEY=
OLLAMA_CLOUD_BASE_URL=
OLLAMA_CLOUD_MODEL=

# Ollama Local (Self-hosted)
# Default local Ollama installation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# Embeddings Configuration
# Model to use for generating text embeddings
EMBEDDING_MODEL=text-embedding-ada-002

# Custom API base for embeddings (optional)
EMBEDDING_API_BASE=

# =============================================================================
# Section 4: Clustering (Optional)
# =============================================================================
# Enable clustering for large bots (250k+ users recommended)
# Clusters allow you to run multiple instances, each handling a subset of shards

# Enable clustering mode (true/false)
CLUSTER_ENABLED=false

# Number of shards per cluster
# Each cluster instance handles this many shards
SHARDS_PER_CLUSTER=1

# Total number of shards across all clusters
# Must be set if clustering is enabled
TOTAL_SHARDS=1

# Cluster ID for this instance (0-indexed)
# Each cluster instance should have a unique ID
CLUSTER_ID=0

# =============================================================================
# Section 5: Rate Limiting
# =============================================================================
# Protect the bot from abuse and API rate limits

# Enable command rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Maximum commands per user per minute
RATE_LIMIT_COMMANDS=10

# =============================================================================
# Section 6: Monitoring and Logging
# =============================================================================
# Track bot health, errors, and performance

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable debug mode (shows detailed error messages to users)
DEBUG=false

# Discord webhook URL for status updates (optional)
STATUS_WEBHOOK=

# Discord webhook URL for error alerts (optional)
ERROR_WEBHOOK=

# Sentry DSN for error tracking (optional)
# Get from: https://sentry.io/
SENTRY_DSN=

# Environment name for Sentry and logging
ENVIRONMENT=production

# =============================================================================
# Section 7: Message Caching
# =============================================================================
# Configure in-memory message caching for context-aware responses

# Maximum number of messages to cache per channel
MAX_MESSAGES=1000

# Time-to-live for cached messages in seconds
MESSAGE_CACHE_TTL=300

# =============================================================================
# Section 8: Security
# =============================================================================
# Encryption and security settings

# Encryption key for sensitive data (API keys, tokens)
# Generate a secure key with: openssl rand -base64 32
ENCRYPTION_KEY=

# =============================================================================
# Section 9: Research and Web Search
# =============================================================================
# External search APIs for research functionality

# Google Custom Search API
# Get from: https://developers.google.com/custom-search/v1/overview
GOOGLE_SEARCH_API_KEY=

# Google Custom Search Engine ID
# Create at: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_CX=

# Bing Search API
# Get from: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SEARCH_API_KEY=
